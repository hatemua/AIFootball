# Dashboard env. Copy to `.env.local` for dev.

# Backend URL (bundled into client code — must be NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Server-side JWT secret used by jose to verify tokens issued by backend.
# MUST match backend's JWT_SECRET exactly.
JWT_SECRET=change-me-to-a-long-random-string
