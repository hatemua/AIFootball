# GPU server env. Copy to `.env` for local dev.

# Path to YOLO weights file
MODEL_PATH=./weights/yolo.pt

# Working directory for downloads + intermediate artifacts
STORAGE_DIR=./storage

# Where this server POSTs callbacks (the backend's public URL)
BACKEND_CALLBACK_BASE_URL=http://localhost:3001

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# AWS S3 (artifacts: inputs, outputs, reports)
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET=talentailabsfootball-874772885665-eu-central-1-an
