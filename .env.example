# ──────────────────────────────────────────────────────────────────
# football-pipeline — root .env.example
#
# This is the unified template. Each service ALSO has its own
# .env.example with only the vars it consumes. Copy the relevant
# section into the service's local .env file.
# ──────────────────────────────────────────────────────────────────

# ─── Shared: Postgres (used by backend + docker-compose) ────────
POSTGRES_USER=football
POSTGRES_PASSWORD=football
POSTGRES_DB=football_pipeline
# Connection string consumed by Drizzle in backend/
DATABASE_URL=postgresql://football:football@localhost:5432/football_pipeline

# ─── Shared: Redis (BullMQ in backend) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Shared: JWT secret ──────────────────────────────────────────
# Backend signs tokens with this. Dashboard verifies with the same value
# (via jose). KEEP IDENTICAL across both services.
JWT_SECRET=change-me-to-a-long-random-string

# ─── Backend (Fastify, port 3001) ────────────────────────────────
PORT=3001
LOG_LEVEL=info
# Where the backend reaches the GPU server (RunPod URL in prod)
GPU_SERVER_URL=http://localhost:8000
# Where the GPU server reaches the backend for callbacks (must be
# publicly addressable in prod)
BACKEND_PUBLIC_URL=http://localhost:3001

# ─── Dashboard (Next.js, port 3000) ──────────────────────────────
# Public-prefixed: bundled into the client. Points at backend.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── GPU Server (FastAPI, port 8000) ─────────────────────────────
# Path on disk to the YOLO model weights
MODEL_PATH=./weights/yolo.pt
# Where downloaded videos and intermediate artifacts live
STORAGE_DIR=./storage
# Used for callback POSTs to the backend
BACKEND_CALLBACK_BASE_URL=http://localhost:3001
