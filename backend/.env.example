# Backend env. Copy to `.env` for local dev.

# Server
PORT=3001
LOG_LEVEL=info

# Postgres (Drizzle)
DATABASE_URL=postgresql://football:football@localhost:5432/football_pipeline

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Auth
# Must be IDENTICAL to dashboard/.env JWT_SECRET so dashboard's jose can verify
JWT_SECRET=change-me-to-a-long-random-string

# GPU server
GPU_SERVER_URL=http://localhost:8000
# Public URL where the GPU server reaches us for callbacks (in prod: your real URL)
BACKEND_PUBLIC_URL=http://localhost:3001

# AWS S3 (artifacts: inputs, outputs, reports)
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET=talentailabsfootball-874772885665-eu-central-1-an
